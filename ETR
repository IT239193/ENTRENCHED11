local HttpService = game:GetService("HttpService")
local CONFIG_FOLDER = "ObsessionConfigs"
if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end

local DROPDOWN_KEYS = { TargetType = true }

local function serializeConfig()
    local data = {}
    for key, val in pairs(Config) do
        if typeof(val) == "Color3" then
            data[key] = { _t = "c3", R = val.R, G = val.G, B = val.B }
        elseif type(val) == "table" then
            data[key] = val
        else
            data[key] = val
        end
    end
    return HttpService:JSONEncode(data)
end

local function deserializeIntoConfig(json)
    local data = HttpService:JSONDecode(json)
    for key, val in pairs(data) do
        if type(val) == "table" and val._t == "c3" then
            Config[key] = Color3.new(val.R, val.G, val.B)
        elseif key == "ESP_ClassFilter" and type(val) == "table" then
            for cName, cVal in pairs(val) do
                Config.ESP_ClassFilter[cName] = cVal
            end
        else
            Config[key] = val
        end
    end
end

local function getConfigList()
    local ok, files = pcall(listfiles, CONFIG_FOLDER)
    if not ok then return {} end
    local names = {}
    for _, path in ipairs(files) do
        local name = string.match(path, "([^/\\]+)%.json$")
        if name then table.insert(names, name) end
    end
    table.sort(names)
    return names
end

local function refreshUI()
    if not Rayfield or not Rayfield.Flags then return end
    for key, val in pairs(Config) do
        if key == "ESP_ClassFilter" then continue end
        if string.sub(key, 1, 5) == "Bind_" then continue end
        local flag = Rayfield.Flags[key]
        if flag then
            pcall(function()
                if DROPDOWN_KEYS[key] then
                    flag:Set({val})
                else
                    flag:Set(val)
                end
            end)
        end
    end
    -- Explicitly sync ForceField toggles using direct references
    pcall(function() if AimFFToggle then AimFFToggle:Set(Config.Aim_FFCheck) end end)
    pcall(function() if TrigFFToggle then TrigFFToggle:Set(Config.Trig_FFCheck) end end)
    pcall(function() if ESPFFToggle then ESPFFToggle:Set(Config.ESP_FFCheck) end end)
    for cName, toggle in pairs(ClassToggles) do
        pcall(function() toggle:Set(Config.ESP_ClassFilter[cName]) end)
    end
    for key, element in pairs(keybindElements) do
        local val = Config[key] or ""
        pcall(function() element:Set(val) end)
    end
    pcall(function()
        if FOVColorPicker then FOVColorPicker:Set(Config.FOVColor) end
        if TrigColorPicker then TrigColorPicker:Set(Config.Trig_TrigFOVColor or Config.Trig_FOVColor) end
        if ESPColorPicker then ESPColorPicker:Set(Config.ESP_Color) end
        if ToolColorPicker then ToolColorPicker:Set(Config.ESP_ToolColor) end
        if ClassColorPicker then ClassColorPicker:Set(Config.ESP_ClassColor) end
    end)
    pcall(UpdateWeightVisibility)
    pcall(UpdateMissVisibility)
    pcall(UpdateClassFilterVisibility)
end

local function saveConfig(name)
    pcall(function()
        writefile(CONFIG_FOLDER .. "/" .. name .. ".json", serializeConfig())
    end)
end

local function loadConfig(name)
    local path = CONFIG_FOLDER .. "/" .. name .. ".json"
    if not isfile(path) then return false end
    local ok = pcall(function()
        deserializeIntoConfig(readfile(path))
        refreshUI()
    end)
    return ok
end

local function deleteConfig(name)
    pcall(function()
        local path = CONFIG_FOLDER .. "/" .. name .. ".json"
        if isfile(path) then delfile(path) end
    end)
end

