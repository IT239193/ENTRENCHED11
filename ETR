local CAS = game:GetService("ContextActionService")
local keybindElements = {}
local function CASBind(Tab, Name, ActionID, ConfigKey, Callback)
    local currentKeycode = nil
    local keybindObj
    keybindObj = Tab:CreateKeybind({
        Name = Name,
        CurrentKeybind = Config[ConfigKey] or "",
        HoldToInteract = false,
        Callback = function()
            -- no-op: CAS handles the actual callback + input sinking
        end,
    })
    keybindElements[ConfigKey] = keybindObj
    task.spawn(function()
        local lastKey = Config[ConfigKey] or ""
        if lastKey ~= "" and lastKey ~= nil then
            local s, kc = pcall(function() return Enum.KeyCode[tostring(lastKey)] end)
            if s and kc then
                currentKeycode = kc
                CAS:BindActionAtPriority(ActionID, function(_, state)
                    if state == Enum.UserInputState.Begin then Callback() end
                    return Enum.ContextActionResult.Sink
                end, false, 99999, kc)
            end
        end
        while task.wait(0.3) do
            pcall(function()
                local curKey = keybindObj.CurrentKeybind or ""
                if curKey ~= lastKey then
                    lastKey = curKey
                    Config[ConfigKey] = curKey
                    if currentKeycode then
                        CAS:UnbindAction(ActionID)
                        currentKeycode = nil
                    end
                    if curKey ~= "" and curKey ~= nil then
                        local s, kc = pcall(function() return Enum.KeyCode[tostring(curKey)] end)
                        if s and kc then
                            currentKeycode = kc
                            CAS:BindActionAtPriority(ActionID, function(_, state)
                                if state == Enum.UserInputState.Begin then Callback() end
                                return Enum.ContextActionResult.Sink
                            end, false, 99999, kc)
                        end
                    end
                end
            end)
        end
    end)
end


